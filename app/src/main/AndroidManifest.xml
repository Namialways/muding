<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PixPinAndroid"
        tools:targetApi="31">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PixPinAndroid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Annotation Editor Activity -->
        <activity
            android:name=".presentation.editor.AnnotationEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <activity
            android:name=".presentation.crop.RegionCropActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <activity
            android:name=".presentation.crop.ImageCropActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <activity
            android:name=".presentation.source.GalleryPinActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <activity
            android:name=".presentation.source.GalleryOcrActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <activity
            android:name=".presentation.source.ClipboardTextPinActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".presentation.ocr.OcrResultActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <activity
            android:name=".presentation.translation.TranslationSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.PixPinAndroid" />

        <!-- Transparent activity used to request MediaProjection permission -->
        <activity
            android:name=".service.ScreenshotPermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Floating Ball Service -->
        <service
            android:name=".service.FloatingBallService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Pin Overlay Service -->
        <service
            android:name=".service.PinOverlayService"
            android:enabled="true"
            android:exported="false" />

        <!-- FileProvider for sharing images -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
